# Lovable Cloud is auto-configured for this project — these vars are managed
# automatically and don't need to be set manually for local development.
# This file documents the variables that exist in the runtime environment.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Optional: public base URL for API / MCP endpoints shown in the UI.
# If set (e.g. a reverse-proxied domain like https://api.saha.team), it is used
# in the copy-paste examples. If unset, ${VITE_SUPABASE_URL}/functions/v1 is used
# so the shown endpoints always point at a working URL.
# VITE_PUBLIC_API_BASE_URL=https://api.saha.team
